# ==========================================================================
# MSA Backup Commander - Example environment file
# Copy to .env and fill with real values. NEVER commit .env to git.
# ==========================================================================

# ---- General ----
APP_NAME="MSA Backup Commander"
APP_ENV=production                  # development | production
TZ=America/Bogota                   # Server timezone (affects Celery Beat)
# Orígenes distintos: plataforma (panel+API+SPA) vs solo Roundcube.
# - DOMAIN_PLATFORM: https://<valor>/api/... , / , /webmail/assign-password
# - DOMAIN_WEBMAIL: https://<valor> = Roundcube (SSO, login). Sin https:// en el valor, solo FQDN.
DOMAIN_PLATFORM=backup.example.com
DOMAIN_WEBMAIL=webmail.example.com

# ---- Security / crypto ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS_MINIMUM
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_44_CHARS_FERNET_KEY_BASE64URLSAFE_ENCODED=
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ---- Database (PostgreSQL) ----
POSTGRES_USER=msabackup
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=msabackup
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- Celery ----
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_CONCURRENCY=2
CELERY_BACKUP_MAX_CONCURRENT=2      # Global concurrent backups cap

# ---- Dovecot ----
# Master user allows the platform to impersonate any virtual user (admin SSO)
DOVECOT_MASTER_USER=backup_admin_master
DOVECOT_MASTER_PASSWORD=CHANGE_ME_LONG_MASTER_PASSWORD

# ---- Roundcube ----
ROUNDCUBE_DES_KEY=CHANGE_ME_24_CHAR_KEY00
# Hostname del servicio Dovecot en la red Docker; IMAP en claro (puerto 143). No uses tls:// aquí.
ROUNDCUBE_DEFAULT_HOST=dovecot
ROUNDCUBE_DEFAULT_PORT=143

# ---- Rclone ----
RCLONE_RC_PORT_RANGE_START=5572
RCLONE_RC_PORT_RANGE_END=5599
# Límite de ancho de banda (ej. 10M). Dejar vacío en su propia línea — no pongas comentarios inline
# tras el = o Docker puede pasar el texto del comentario a RCLONE_BWLIMIT y rclone falla al arrancar.
RCLONE_BWLIMIT=
# Segundos para GYB --estimate en Cuentas → Comprobar. 0 = sin límite (hasta terminar).
ACCOUNT_VERIFY_GYB_TIMEOUT_SECONDS=0

# ---- Google Workspace (set via wizard; placeholders only) ----
# These values are actually persisted encrypted in sys_settings.
# Only here for reference of what the wizard will ask for.
# GOOGLE_SA_JSON_PATH=/app/secrets/service-account.json
# GOOGLE_ADMIN_IMPERSONATE=admin@example.com
# GOOGLE_WORKSPACE_DOMAIN=example.com
# VAULT_SHARED_DRIVE_ID=0A1B2C3D4E5F6G7H8I
# GMAIL_SENDER_IMPERSONATE=no-reply@example.com

# ---- Notifications ----
TELEGRAM_BOT_TOKEN=                  # Optional, set via UI preferred
TELEGRAM_DEFAULT_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ---- Platform backup ----
# Una sola línea: la clave pública age1... (sin comentarios en la misma variable; si ponés varias líneas, se usa la primera que no empiece con #)
PLATFORM_BACKUP_AGE_RECIPIENT=
PLATFORM_BACKUP_DAILY_HOUR=3         # 0-23, local TZ
PLATFORM_BACKUP_RETENTION_DAILY=7
PLATFORM_BACKUP_RETENTION_WEEKLY=4
PLATFORM_BACKUP_RETENTION_MONTHLY=12

# ---- Git refresh ----
GIT_REFRESH_MODE=webhook             # webhook | bind_mount | both
GIT_REPO_URL=https://github.com/DanyTrax/backup-driveGWS.git
GIT_BRANCH=main
# Ruta dentro del contenedor que tenga .git (la imagen estándar NO tiene .git en /app).
# En VPS normal: no uses Git refresh desde la UI; hacé git pull en el host y rebuild.
# GIT_WORKING_TREE=/data/repo

# ---- Logging ----
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_JSON=true
LOG_RETENTION_DAYS=30

# ---- Rate limiting ----
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_MAGIC_LINK_PER_HOUR=3
RATE_LIMIT_API_PER_MINUTE=60

# ---- Feature flags ----
FEATURE_WEBMAIL_ENABLED=true
FEATURE_MFA_REQUIRED_FOR_SUPERADMIN=false
FEATURE_WEB_PUSH=false               # Fase 2

# ---- Docker network ----
# Must be created once: docker network create proxy-net
PROXY_NETWORK_NAME=proxy-net
